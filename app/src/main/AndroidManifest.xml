<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <!--
      extractNativeLibs="true" WAJIB: bikin .so renderer di-extract ke disk,
      biar launcher (Zalith/FCL/Pojav) bisa dlopen dari nativeLibraryDir plugin.
      Tanpa ini, .so kekompres di APK dan renderer gagal di-load.
    -->
    <application
        android:allowBackup="true"
        android:extractNativeLibs="true"
        android:label="NGG FPS Renderer"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.Light.DarkActionBar">

        <!--
          KUNCI DETEKSI: launcher scan installed apps yg punya fclPlugin=true.
          Sebelumnya gua isi "renderer" -> makanya gak kebaca sama sekali.
        -->
        <meta-data
            android:name="fclPlugin"
            android:value="true" />

        <!-- Definisi renderer: NAMA:lib_render.so:lib_egl.so -->
        <meta-data
            android:name="renderer"
            android:value="${renderer}" />

        <!-- Deskripsi yang muncul di daftar renderer launcher -->
        <meta-data
            android:name="des"
            android:value="${des}" />

        <!-- Env var FPS untuk Boat/Zalith runtime -->
        <meta-data
            android:name="boatEnv"
            android:value="${boatEnv}" />

        <!-- Env var FPS untuk PojavGlowWorm runtime -->
        <meta-data
            android:name="pojavEnv"
            android:value="${pojavEnv}" />

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
